    "for i, (X_chunk, y_chunk) in enumerate(chunks, start=1):\n",
    "    log = ensemble_trainer.fit_chunk(X_chunk, y_chunk)\n",
    "    print(\n",
    "        f\"Chunk {i:02d} | \"\n",
    "        f\"chunk accuracy={log['chunk_accuracy']:.3f} | \"\n",
    "        f\"cumulative accuracy={log['cumulative_accuracy']:.3f} | \"\n",
    "        f\"memory={log['memory_bytes'] / 1024:.1f} KB\"\n",
    "    )\n",
    "\n",
    "ensemble_logs = ensemble_trainer.logs()\n",
    "ensemble_accuracy = [row[\"cumulative_accuracy\"] for row in ensemble_logs]\n",
    "ensemble_chunk_accuracy = [row[\"chunk_accuracy\"] for row in ensemble_logs]\n",
    "\n",
    "print(\"Final ensemble cumulative accuracy:\", ensemble_accuracy[-1])\n"
   ]
  },
